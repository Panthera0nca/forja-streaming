"""KafkaConsumer base — wrapper sobre confluent-kafka."""
from __future__ import annotations

import json
import os
from typing import Any, Iterator

from confluent_kafka import Consumer as ConfluentConsumer, KafkaError
from dotenv import load_dotenv

load_dotenv()


class BaseKafkaConsumer:
    """Consume mensajes JSON de uno o más topics de Kafka."""

    topics: list[str] = ["{{ package_name }}.events"]
    group_id: str = "{{ package_name }}-consumer"

    def __init__(self) -> None:
        self._consumer = ConfluentConsumer({
            "bootstrap.servers": os.getenv("KAFKA_BOOTSTRAP_SERVERS", "localhost:9092"),
            "group.id":          self.group_id,
            "auto.offset.reset": "earliest",
            "enable.auto.commit": False,
        })
        self._consumer.subscribe(self.topics)

    def deserialize(self, raw: bytes) -> Any:
        """Deserializa bytes a dict. Sobreescribí para formatos custom."""
        return json.loads(raw.decode())

    def __iter__(self) -> Iterator[Any]:
        while True:
            msg = self._consumer.poll(timeout=1.0)
            if msg is None:
                continue
            if msg.error():
                if msg.error().code() == KafkaError._PARTITION_EOF:
                    continue
                raise RuntimeError(f"Error Kafka: {msg.error()}")
            yield self.deserialize(msg.value())

    def commit(self) -> None:
        self._consumer.commit(asynchronous=False)

    def close(self) -> None:
        self._consumer.close()
