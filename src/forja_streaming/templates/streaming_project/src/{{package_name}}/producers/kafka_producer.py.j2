"""KafkaProducer base — wrapper sobre confluent-kafka."""
from __future__ import annotations

import json
import os
from typing import Any

from confluent_kafka import Producer as ConfluentProducer
from dotenv import load_dotenv

load_dotenv()


class BaseKafkaProducer:
    """Produce mensajes JSON a un topic de Kafka.

    Subclasificá y sobreescribí `serialize()` para formatos custom.
    """

    topic: str = "{{ package_name }}.events"

    def __init__(self) -> None:
        self._producer = ConfluentProducer({
            "bootstrap.servers": os.getenv("KAFKA_BOOTSTRAP_SERVERS", "localhost:9092"),
        })

    def serialize(self, event: Any) -> bytes:
        """Serializa el evento a bytes. Default: JSON."""
        if hasattr(event, "model_dump"):
            return json.dumps(event.model_dump(), default=str).encode()
        return json.dumps(event, default=str).encode()

    def produce(self, event: Any) -> None:
        self._producer.produce(
            self.topic,
            value=self.serialize(event),
            on_delivery=self._on_delivery,
        )
        self._producer.poll(0)

    def flush(self) -> None:
        self._producer.flush()

    @staticmethod
    def _on_delivery(err, msg) -> None:
        if err:
            raise RuntimeError(f"Error produciendo mensaje: {err}")
