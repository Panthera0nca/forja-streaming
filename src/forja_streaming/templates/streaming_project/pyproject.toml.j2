[project]
name = "{{ package_name }}"
version = "0.1.0"
description = "Proyecto streaming generado con forja"
requires-python = ">={{ python_version }}"
dependencies = [
    "confluent-kafka>=2.4.0",
    "pydantic>=2.9.0",
    "python-dotenv>=1.0.0",
    "rich>=13.9.0",
]

[project.optional-dependencies]
lakehouse = [
    "forja-lakehouse>=0.1.0",   # sink hacia Delta Lake
    "polars>=0.20.0",
    "deltalake>=0.17.0",
]
dev = [
    "pytest>=8.0",
    "ruff>=0.7",
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{ package_name }}"]

[tool.ruff]
target-version = "py312"
line-length = 100

[tool.pytest.ini_options]
testpaths = ["tests"]
pythonpath = ["src"]
